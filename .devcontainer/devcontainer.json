{
  "remoteUser" : "vscode",
  
  "forwardPorts" : [ "12345", "7777" ],
  "name" : "scicloj.ml.smile",
  "build" : {
    "dockerfile" : "Dockerfile"
  },
  "remoteEnv" : {
    "PATH" : "${containerEnv:PATH}:/home/vscode/.asdf/shims"
  },
  "customizations" : {
    "vscode" : {
      "settings" : { },
      "extensions" : [
        "vscjava.vscode-java-pack",
        "betterthantomorrow.calva",
        "eamodio.gitlens",
        "zhaouv.vscode-markdown-everywhere"
      ]
    }
  },
  "mounts": [
        "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached"
    ],
  "features" : {
    "ghcr.io/devcontainers-extra/features/clojure-asdf:2" : {"version": "1.12.4.1618" },
    "ghcr.io/devcontainers-extra/features/bash-command:1" : {
      "command" : "apt-get update && apt-get install -y rlwrap libxi6 libxtst6 libxrender1 libfreetype6-dev fontconfig x11-apps"
    }


  },
  "postCreateCommand" : "sudo ln -fs /home/vscode/.asdf/shims/clojure /usr/local/bin/",
  "postStartCommand" : "clojure -P -Sthreads 1"
}
